{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "swe-team",
  "version": "0.1.0",
  "identifier": "com.gokulpm.sweteam",
  "build": {
    "frontendDist": "../frontend"
  },
  "app": {
    "withGlobalTauri": true,
    "windows": [
      {
        "title": "SWE Team",
        "width": 900,
        "height": 700,
        "resizable": true,
        "fullscreen": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/driver"
    ],
    "resources": {
      "../../team-brief.md": "team-brief.md",
      "../../orchestrator.md": "orchestrator.md",
      "../../agents/architect.md": "agents/architect.md",
      "../../agents/coder-backend.md": "agents/coder-backend.md",
      "../../agents/coder-cpp.md": "agents/coder-cpp.md",
      "../../agents/coder-frontend.md": "agents/coder-frontend.md",
      "../../agents/coder-python.md": "agents/coder-python.md",
      "../../agents/pm.md": "agents/pm.md",
      "../../agents/qa.md": "agents/qa.md"
    }
  }
}
