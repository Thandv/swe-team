# Generated project workspaces — the team produces these; they are not source.
# To keep one as a reference fixture, add an explicit `!path/` exception below.
/*-smoke/
/*-build/

# Per-project venvs (e.g. csv2json-service/.venv-qa/ that QA used to run tests).
**/.venv*/
**/__pycache__/

# Phase-2 binary build outputs.
/binary/dist/
/binary/build/
/binary/target/
/binary/node_modules/

# Python
__pycache__/
*.py[cod]
*.egg-info/
.venv/
venv/

# Editor / OS
.DS_Store
.idea/
.vscode/
*.swp

# Local-only Claude artifacts (live under ../.claude/, not in this repo)

# Secret keys — the driver reads these from keys.env files at standard paths.
# Never commit. Catches the common typos too (.env, .keys.env, etc.).
keys.env
**/keys.env
.env
**/.env
*.key
**/*.key
